{
  "$schema": "./schema.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#df6951",
          "name": "Orange",
          "slug": "orange"
        },
        {
          "color": "#f1a501",
          "name": "Yellow",
          "slug": "yellow"
        },
        {
          "color": "#14183e",
          "name": "Dark blue",
          "slug": "dark-blue"
        },
        {
          "color": "#5e6282",
          "name": "Light blue",
          "slug": "light-blue"
        },
        {
          "color": "#686d77",
          "name": "Gray",
          "slug": "gray"
        },
        {
          "color": "#e5e5e5",
          "name": "Light gray",
          "slug": "light-gray"
        },
        {
          "color": "#6246e5",
          "name": "Purple",
          "slug": "purple"
        },
        {
          "color": "#fff1da",
          "name": "Light yellow",
          "slug": "light-yellow"
        },
        {
          "color": "#006380",
          "name": "Teal",
          "slug": "teal"
        },
        {
          "color": "#dfd7f9",
          "name": "Light purple",
          "slug": "light-purple"
        },
        {
          "color": "#212832",
          "name": "Dark gray",
          "slug": "dark-gray"
        }
      ]
    },
    "layout": {
      "contentSize": "1024px",
      "wideSize": "1210px"
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "Tiny",
          "size": "10px",
          "slug": "20"
        },
        {
          "name": "X-Small",
          "size": "20px",
          "slug": "30"
        },
        {
          "name": "Small",
          "size": "30px",
          "slug": "40"
        },
        {
          "name": "Regular",
          "size": "clamp(30px, 5vw, 50px)",
          "slug": "50"
        },
        {
          "name": "Large",
          "size": "clamp(30px, 7vw, 70px)",
          "slug": "60"
        },
        {
          "name": "X-Large",
          "size": "clamp(50px, 7vw, 90px)",
          "slug": "70"
        },
        {
          "name": "XX-Large",
          "size": "clamp(70px, 10vw, 140px)",
          "slug": "80"
        }
      ],
      "units": [
        "%",
        "px",
        "em",
        "rem",
        "vh",
        "vw"
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontSizes": [
        {
          "fluid": false,
          "name": "X-Small",
          "size": ".8125rem",
          "slug": "x-small"
        },
        {
          "fluid": false,
          "name": "Small",
          "size": ".875rem",
          "slug": "small"
        },
        {
          "fluid": false,
          "name": "Medium",
          "size": "1rem",
          "slug": "medium"
        },
        {
          "fluid": false,
          "name": "Large",
          "size": "1.125rem",
          "slug": "large"
        },
        {
          "fluid": false,
          "name": "X-Large",
          "size": "1.25rem",
          "slug": "x-large"
        },
        {
          "fluid": false,
          "name": "XX-Large",
          "size": "1.5rem",
          "slug": "xx-large"
        },
        {
          "fluid": false,
          "name": "XXX-Large",
          "size": "2.0625rem",
          "slug": "xxx-large"
        },
        {
          "fluid": false,
          "name": "Huge",
          "size": "3.125rem",
          "slug": "huge"
        },
        {
          "fluid": false,
          "name": "X-Huge",
          "size": "4rem",
          "slug": "x-huge"
        },
        {
          "fluid": false,
          "name": "XX-Huge",
          "size": "5.25rem",
          "slug": "xx-huge"
        }
      ],
      "fontFamilies": [
        {
          "name": "Volkhov",
          "slug": "volkhov",
          "fontFamily": "Volkhov, serif",
          "fontFace": [
            {
              "src": [
                "file:./assets/fonts/volkhov/Volkhov-Regular.ttf"
              ],
              "fontWeight": "400",
              "fontStyle": "normal",
              "fontFamily": "Volkhov"
            },
            {
              "src": [
                "file:./assets/fonts/volkhov/Volkhov-Bold.ttf"
              ],
              "fontWeight": "700",
              "fontStyle": "normal",
              "fontFamily": "Volkhov"
            },
            {
              "src": [
                "file:./assets/fonts/volkhov/Volkhov-Italic.ttf"
              ],
              "fontWeight": "400",
              "fontStyle": "italic",
              "fontFamily": "Volkhov"
            },
            {
              "src": [
                "file:./assets/fonts/volkhov/Volkhov-BoldItalic.ttf"
              ],
              "fontWeight": "700",
              "fontStyle": "italic",
              "fontFamily": "Volkhov"
            }
          ]
        },
        {
          "name": "Inter",
          "slug": "inter",
          "fontFamily": "Inter, sans-serif",
          "fontFace": [
            {
              "src": [
                "file:./assets/fonts/inter/Inter-VariableFont_opsz,wght.woff2"
              ],
              "fontWeight": "100 800",
              "fontStyle": "normal",
              "fontFamily": "Inter"
            },
            {
              "src": [
                "file:./assets/fonts/inter/Inter-Italic-VariableFont_opsz,wght.woff2"
              ],
              "fontWeight": "100 800",
              "fontStyle": "italic",
              "fontFamily": "Inter"
            }
          ]
        },
        {
          "name": "Montserrat",
          "slug": "montserrat",
          "fontFamily": "Montserrat, sans-serif",
          "fontFace": [
            {
              "src": [
                "file:./assets/fonts/montserrat/Montserrat-VariableFont_wght.woff2"
              ],
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontFamily": "Inter"
            },
            {
              "src": [
                "file:./assets/fonts/montserrat/Montserrat-Italic-VariableFont_wght.woff2"
              ],
              "fontWeight": "100 900",
              "fontStyle": "italic",
              "fontFamily": "Inter"
            }
          ]
        },
        {
          "name": "Open Sans",
          "slug": "open-sans",
          "fontFamily": "\"Open Sans\", sans-serif",
          "fontFace": [
            {
              "src": [
                "file:./assets/fonts/open-sans/OpenSans-VariableFont_wdth,wght.woff2"
              ],
              "fontWeight": "300 800",
              "fontStyle": "normal",
              "fontFamily": "Inter"
            },
            {
              "src": [
                "file:./assets/fonts/open-sans/OpenSans-Italic-VariableFont_wdth,wght.woff2"
              ],
              "fontWeight": "300 800",
              "fontStyle": "italic",
              "fontFamily": "Inter"
            }
          ]
        },
        {
          "name": "Poppins",
          "slug": "poppins",
          "fontFamily": "Poppins, sans-serif",
          "fontFace": [
            {
              "src": [
                "file:./assets/fonts/poppins/Poppins-VariableFont_wght.woff2"
              ],
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontFamily": "Inter"
            },
            {
              "src": [
                "file:./assets/fonts/poppins/Poppins-Italic-VariableFont_wght.woff2"
              ],
              "fontWeight": "100 900",
              "fontStyle": "italic",
              "fontFamily": "Inter"
            }
          ]
        },
        {
          "name": "Quicksand",
          "slug": "quicksand",
          "fontFamily": "Quicksand, sans-serif",
          "fontFace": [
            {
              "src": [
                "file:./assets/fonts/quicksand/Quicksand-VariableFont_wght.woff2"
              ],
              "fontWeight": "300 700",
              "fontStyle": "normal",
              "fontFamily": "Inter"
            }
          ]
        },
        {
          "name": "Roboto",
          "slug": "roboto",
          "fontFamily": "Roboto, sans-serif",
          "fontFace": [
            {
              "src": [
                "file:./assets/fonts/roboto/Roboto-VariableFont_wdth_wght.woff"
              ],
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontFamily": "Inter"
            },
            {
              "src": [
                "file:./assets/fonts/roboto/Roboto-Italic-VariableFont_wdth_wght.woff"
              ],
              "fontWeight": "100 900",
              "fontStyle": "italic",
              "fontFamily": "Inter"
            }
          ]
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "typography": {
      "fontFamily": "var:preset|font-family|poppins",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "400",
      "lineHeight": "1.3"
    },
    "color": {
      "text": "var:preset|color|light-blue"
    },
    "spacing": {
      "blockGap": "1rem",
      "padding": {
        "left": "var:preset|spacing|50",
        "right": "var:preset|spacing|50"
      }
    },
    "elements": {
      "button": {
        "color": {
          "background": "var:preset|color|yellow",
          "text": "var:preset|color|white"
        },
        "css": "& { transition: all 0.15s ease-in;position:relative } &::before { content: ''; position: absolute; inset:0;width: 100%; height: 100%;opacity: 0.15;z-index: -1;transition: all 0.15s ease-in;border-radius: 10px;filter: blur(10px);top: 10px;background-color: var(--wp--preset--color--yellow)}",
        "spacing": {
          "padding": {
            "top": "18px",
            "right": "27px",
            "bottom": "18px",
            "left": "27px"
          }
        },
        "border": {
          "color": "transparent",
          "width": "1px",
          "style": "solid",
          "radius": "10px"
        },
        "typography": {
          "fontSize": "var:preset|font-size|medium",
          "fontWeight": "400"
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|orange"
          }
        }
      },
      "caption": {
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "lineHeight": "1.4"
        }
      },
      "h1": {
        "typography": {
          "fontWeight": "700",
          "fontFamily": "var:preset|font-family|volkhov",
          "fontSize": "var:preset|font-size|xx-huge"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "15px"
          }
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|huge"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "10px"
          }
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|xxx-large"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "10px"
          }
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "10px"
          }
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var:preset|font-size|x-large"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "10px"
          }
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var:preset|font-size|large"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "10px"
          }
        }
      },
      "heading": {
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1"
        },
        "color": {
          "text": "var:preset|color|dark-blue"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|dark-blue"
        },
        "css": "& {transition: all 0.15s ease-in}",
        ":hover": {
          "color": {
            "text": "var:preset|color|orange"
          }
        }
      }
    },
    "blocks": {
      "core/query": {},
      "core/post-template": {
        "spacing": {
          "padding": {
            "top": "0",
            "bottom": "10px",
            "left": "0",
            "right": "0"
          }
        },
        "css": ".wp-block-post-template .wp-block-post {display: flex;flex-direction: column;border-radius: 10px;overflow: hidden;background: white;padding-bottom: 10px;box-shadow: 0px 20px 40px 0px rgba(4, 5, 40, 0.04);}"
      },
      "core/post-title": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontSize": "1.375rem",
          "lineHeight": "1.3"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0",
            "left": "0",
            "right": "0"
          },
          "padding": {
            "top": "10px",
            "bottom": "5px",
            "left": "20px",
            "right": "20px"
          }
        },
        "css": ".wp-block-post-title a {color: red} .wp-block-post-title a:hover{color: green;}"
      },
      "core/post-date": {
        "typography": {
          "fontSize": "0.875rem",
          "lineHeight": "1.3"
        },
        "spacing": {
          "padding": {
            "top": "5px",
            "bottom": "5px",
            "left": "20px",
            "right": "20px"
          }
        },
        "css": ".wp-block-post-date time {background-color: var(--wp--preset--color--light-orange);color: #975e0c;padding: 2px 8px; border-radius: 5px;}"
      },
      "core/post-featured-image": {
        "css": ".wp-block-post-featured-image img {width: 100%; height: 204px;object-fit: cover;}"
      },
      "core/post-excerpt": {
        "color": {
          "text": "#333"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0",
            "left": "0",
            "right": "0"
          },
          "padding": {
            "top": "5px",
            "bottom": "5px",
            "left": "20px",
            "right": "20px"
          }
        },
        "typography": {
          "fontSize": "0.938rem",
          "lineHeight": "1.3"
        }
      },
      "core/post-author": {
        "color": {
          "text": "#333"
        },
        "spacing": {
          "padding": {
            "top": "5px",
            "bottom": "5px",
            "left": "20px",
            "right": "20px"
          }
        },
        "typography": {
          "fontSize": "0.938rem",
          "lineHeight": "1.3",
          "fontWeight": "600"
        },
        "css": "&{align-items: center;} & img {border-radius: 9999px;}"
      },
      "core/button": {
        "variations": {
          "outline": {
            "color": {
              "background": "white",
              "text": "var:preset|color|yellow"
            },
            "css": "&:hover {background: var(--wp--preset--color--yellow);color: white} &::before {display: none}",
            "border": {
              "color": "var:preset|color|yellow",
              "width": "1px"
            },
            "spacing": {
              "padding": {
                "top": "18px",
                "right": "27px",
                "bottom": "18px",
                "left": "27px"
              }
            }
          },
          "blue": {
            "color": {
              "background": "var:preset|color|blue",
              "text": "var:preset|color|base"
            },
            "css": ".wp-block-button__link:hover{background: var(--wp--preset--color--dark-blue);border-color: var(--wp--preset--color--dark-blue)}",
            "spacing": {
              "padding": {
                "top": "8px",
                "right": "25px",
                "bottom": "8px",
                "left": "25px"
              }
            },
            "border": {
              "color": "var:preset|color|blue"
            }
          },
          "orange": {
            "color": {
              "background": "var:preset|color|orange",
              "text": "var:preset|color|base"
            },
            "css": ".wp-block-button__link:hover{background: var(--wp--preset--color--dark-orange);border-color: var(--wp--preset--color--dark-orange)}",
            "spacing": {
              "padding": {
                "top": "8px",
                "right": "25px",
                "bottom": "8px",
                "left": "25px"
              }
            },
            "border": {
              "color": "var:preset|color|orange"
            }
          }
        }
      },
      "core/navigation": {
        "typography": {},
        "elements": {
          "link": {
            ":hover": {
              "color": {
                "text": "var:preset|color|orange"
              }
            },
            "typography": {
              "fontWeight": "500",
              "textDecoration": "none"
            }
          }
        }
      },
      "core/paragraph": {
        "typography": {
          "fontSize": "var:preset|font-size|medium",
          "lineHeight": "1.6"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "10px"
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header"
    },
    {
      "area": "footer",
      "name": "footer"
    }
  ]
}